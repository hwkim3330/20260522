<UserControl x:Class="EthernetPacketGenerator.Views.NdjsonBridgeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <!-- Row 0: Peer URL + Probe -->
            <RowDefinition Height="Auto"/>
            <!-- Row 1: Interface list + Start/Stop/Clear -->
            <RowDefinition Height="Auto"/>
            <!-- Row 2: Target address + Check + Result -->
            <RowDefinition Height="Auto"/>
            <!-- Row 3: Packet DataGrid -->
            <RowDefinition Height="*"/>
            <!-- Row 4: Detail pane -->
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <!-- ── Row 0: Peer URL bar ───────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceAltBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,10"
                Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <TextBlock DockPanel.Dock="Left"
                           Text="Peer URL"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="{StaticResource MutedForeground}"
                           FontSize="12"/>

                <Button DockPanel.Dock="Right"
                        Content="Probe"
                        Width="90"
                        Margin="10,0,0,0"
                        Command="{Binding ProbeCommand}"/>

                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Status}"
                           VerticalAlignment="Center"
                           Margin="12,0,0,0"
                           Foreground="{StaticResource AccentBrush}"
                           FontSize="12"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="480"/>

                <TextBox Text="{Binding PeerUrl, UpdateSourceTrigger=PropertyChanged}"
                         Height="30"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas"
                         Background="#05080D"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         Padding="8,0"
                         MaxWidth="340"/>
            </DockPanel>
        </Border>

        <!-- ── Row 1: Interface chips + capture controls ─────────────────── -->
        <Border Grid.Row="1"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8"
                Margin="0,0,0,8">
            <DockPanel LastChildFill="True">
                <!-- Capture control buttons on the right -->
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="10,0,0,0">
                    <Button Content="▶ Start Capture"
                            Width="118"
                            Margin="4,0"
                            Command="{Binding StartCommand}"/>
                    <Button Content="■ Stop"
                            Width="62"
                            Margin="4,0"
                            Command="{Binding StopCommand}"/>
                    <Button Content="Clear"
                            Width="62"
                            Margin="4,0"
                            Command="{Binding ClearCommand}"/>
                </StackPanel>

                <!-- Interface checkboxes on the left -->
                <DockPanel LastChildFill="True">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Peer Interfaces"
                               Style="{StaticResource PanelHeader}"
                               Margin="0,0,0,6"/>
                    <ScrollViewer VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding PeerInterfaces}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}"
                                              Content="{Binding DisplayName}"
                                              Margin="0,2,16,2"
                                              Foreground="{StaticResource ForegroundBrush}"
                                              FontFamily="Consolas"
                                              FontSize="12"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </DockPanel>
        </Border>

        <!-- ── Row 2: Target address + Check + Result ────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="10,8"
                Margin="0,0,0,8">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Text="Target Address"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{StaticResource MutedForeground}"
                           FontSize="12"/>

                <TextBox DockPanel.Dock="Left"
                         Text="{Binding TargetAddress, UpdateSourceTrigger=PropertyChanged}"
                         Width="280"
                         Height="30"
                         VerticalContentAlignment="Center"
                         FontFamily="Consolas"
                         Background="#05080D"
                         Foreground="{StaticResource ForegroundBrush}"
                         BorderBrush="{StaticResource BorderBrush}"
                         Padding="8,0">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding CheckCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button DockPanel.Dock="Left"
                        Content="Check"
                        Width="72"
                        Margin="8,0,0,0"
                        Command="{Binding CheckCommand}"/>

                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding ResultText}"
                           VerticalAlignment="Center"
                           Margin="16,0,0,0"
                           Foreground="{StaticResource AccentBrush}"
                           FontWeight="SemiBold"
                           FontSize="13"/>
            </DockPanel>
        </Border>

        <!-- ── Row 3: Packet DataGrid ────────────────────────────────────── -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Packets}"
                  SelectedItem="{Binding SelectedPacket, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  IsReadOnly="True"
                  HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal"
                  Background="Transparent"
                  BorderBrush="{StaticResource BorderBrush}"
                  BorderThickness="1"
                  RowHeight="26"
                  Margin="0,0,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="No"        Binding="{Binding No}"            Width="52"/>
                <DataGridTextColumn Header="Time"      Binding="{Binding Time}"           Width="100"/>
                <DataGridTextColumn Header="Interface" Binding="{Binding InterfaceName}"  Width="160"/>
                <DataGridTextColumn Header="Src MAC"   Binding="{Binding SrcMac}"         Width="130"/>
                <DataGridTextColumn Header="Dst MAC"   Binding="{Binding DstMac}"         Width="130"/>
                <DataGridTextColumn Header="Source"    Binding="{Binding Source}"         Width="120"/>
                <DataGridTextColumn Header="Dest"      Binding="{Binding Destination}"    Width="120"/>
                <DataGridTextColumn Header="Protocol"  Binding="{Binding Protocol}"       Width="78"/>
                <DataGridTextColumn Header="Len"       Binding="{Binding Length}"         Width="56"/>
                <DataGridTextColumn Header="Info"      Binding="{Binding Info}"           Width="*"/>
            </DataGrid.Columns>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Setter Property="Foreground" Value="{StaticResource ForegroundBrush}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsMatch}" Value="True">
                            <Setter Property="Background" Value="#1A3A6A"/>
                            <Setter Property="FontWeight"  Value="SemiBold"/>
                        </DataTrigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#2A4A8A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- ── Row 4: Selected packet detail ────────────────────────────── -->
        <Grid Grid.Row="4" Margin="0,6,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="6"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <GridSplitter Grid.Row="0"
                          Height="6"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}"/>

            <TextBox Grid.Row="1"
                     x:Name="DetailTextBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     Background="#05080D"
                     Foreground="{StaticResource ForegroundBrush}"
                     BorderBrush="{StaticResource BorderBrush}"
                     BorderThickness="1"
                     FontFamily="Consolas"
                     FontSize="12"
                     Padding="8"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     Text="{Binding SelectedDetailText, Mode=OneWay}"/>
        </Grid>
    </Grid>
</UserControl>
